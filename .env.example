# Backend BFF target. Required in production — the Next.js app refuses
# to boot at runtime if NODE_ENV=production and this is unset (see
# server/api/apiRoutes.ts and lib/resolve-file-url.ts). Dev falls back
# to http://localhost:8080/ebook.
#
# Copy this file to .env.local for your dev environment:
#     cp .env.example .env.local
# and set the value below to whichever backend you're targeting.
BACKEND_URL=https://pulmo-be.onrender.com/ebook
